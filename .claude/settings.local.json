{
  "permissions": {
    "allow": [
      "Bash(php -l pages/shop-dashboard.php)",
      "Bash(php -l pages/shop-orders.php)",
      "Bash(php -l pages/shop-pricing.php)",
      "Bash(php -l pages/shop-referrals.php)",
      "Bash(php -l application/configs/csrf.php)",
      "Bash(php -l application/configs/shop_pdo.php)",
      "Bash(php -l application/models/ProductDisplay.php)",
      "Bash(php -l application/models/ProductPricing.php)",
      "Bash(php -l templates/sidebar.php)",
      "Bash(php -S localhost:8080 router.php)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:8080/shop/dashboard)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:8080/shop/orders)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:8080/shop/pricing)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:8080/shop/referrals)",
      "Bash(taskkill /F /IM php.exe)",
      "Bash(php -r ' *)"
    ]
  }
}
